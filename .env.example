# =============================================================================
# Required
# =============================================================================

# Laravel API base URL. Keep only one active value.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api

# Local Apache/XAMPP style backend:
# EXPO_PUBLIC_API_URL=http://127.0.0.1/rental-backend/public/api

# Physical mobile device on same Wi-Fi:
# EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8000/api
# EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8001/api
# EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP/rental-backend/public/api

# Google Maps API key. Required for Android map rendering.
# Restrict by application + SHA-1 in Google Cloud Console before shipping.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# =============================================================================
# Optional
# =============================================================================

# One of: development | staging | production. Defaults to development.
EXPO_PUBLIC_APP_ENV=development

# Sentry DSN for crash reporting. Leave empty to disable.
EXPO_PUBLIC_SENTRY_DSN=

# EAS project id (UUID). Required for push notifications.
# Get it from: https://expo.dev/accounts/<your-account>/projects/<project>
# Or run: eas project:init
EXPO_PUBLIC_EAS_PROJECT_ID=

# Hostname for Universal Links (iOS) / App Links (Android).
# Leave empty to ship with the custom rentalapp:// scheme only.
# When set, you must also host:
#   https://<host>/.well-known/apple-app-site-association
#   https://<host>/.well-known/assetlinks.json
# EXPO_PUBLIC_UNIVERSAL_LINK_HOST=rental-app.com
EXPO_PUBLIC_UNIVERSAL_LINK_HOST=
